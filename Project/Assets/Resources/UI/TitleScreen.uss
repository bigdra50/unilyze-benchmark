/* TitleScreen.uss */

#title-root {
    flex-grow: 1;
    background-color: #1a1a2e;
    justify-content: center;
    align-items: center;
}

#title-label {
    font-size: 56px;
    color: #e94560;
    margin-bottom: 8px;
    letter-spacing: 4px;
}

#subtitle-label {
    font-size: 20px;
    color: #e0e0e0;
    margin-bottom: 48px;
    opacity: 0.7;
}

#button-container {
    align-items: center;
}

#button-container > .btn {
    width: 260px;
    margin-bottom: 12px;
}
